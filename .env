# Airflow
AIRFLOW_URL=http://10.0.0.12:8080
AIRFLOW_USER=Diego
AIRFLOW_PASSWORD=datax123

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=platform_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# Extractor
REGION=BO
POLL_INTERVAL_SECONDS=10

# Publisher: stdout | redis
PUBLISHER_TYPE=redis

# State repository: memory | sql
STATE_REPOSITORY_TYPE=sql


AIRFLOW_REQUEST_TIMEOUT_SECONDS=40
TASK_INSTANCES_BATCH_SIZE=50

# Ventana de extracción: solo DAG runs iniciados en los últimos N días
# Sube este valor en producción (ej: 7). Para pruebas usar 1.
DAG_RUNS_LOOKBACK_DAYS=1